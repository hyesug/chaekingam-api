# .env.example - 이 파일을 복사해서 .env로 만들고 실제 값을 채우세요.
# cp .env.example .env

# 데이터베이스
DB_USERNAME=chaekingam
DB_PASSWORD=your-strong-password

# 프로덕션 전용: RDS 엔드포인트 (docker-compose.prod.yml에서 사용)
DB_HOST=your-rds-endpoint.rds.amazonaws.com

# JWT
# 최소 32자 이상의 랜덤 문자열을 사용하세요. 예: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters-long

# OAuth 로그인
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 책 검색 API
KAKAO_API_KEY=
GOOGLE_API_KEY=

# 추후 기능용 외부 API
DEEPL_API_KEY=
TOSS_SECRET_KEY=

# 앱 URL
FRONTEND_URL=https://your-domain.vercel.app
BACKEND_URL=https://your-api-domain.com

# Docker Hub (CI/CD 또는 프로덕션 compose에서 사용)
DOCKERHUB_USERNAME=your-dockerhub-username
