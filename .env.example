# .env.example — 이 파일을 복사해서 .env로 만들고 실제 값을 채우세요
# cp .env.example .env

# 데이터베이스
DB_USERNAME=chaekingam
DB_PASSWORD=your-strong-password

# 프로덕션 전용: RDS 엔드포인트 (docker-compose.prod.yml에서 사용)
DB_HOST=your-rds-endpoint.rds.amazonaws.com

# JWT
# 최소 32자 이상의 랜덤 문자열 (openssl rand -base64 32 로 생성)
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters-long

# 카카오 OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 네이버 OAuth
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 구글 OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 앱 URL
FRONTEND_URL=https://your-domain.vercel.app
BACKEND_URL=https://your-ec2-domain.com

# Docker Hub (CI/CD에서 자동 설정, 로컬에선 불필요)
DOCKERHUB_USERNAME=your-dockerhub-username
